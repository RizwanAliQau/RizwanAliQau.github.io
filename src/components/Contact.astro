---
import { site } from '../data/site';
---

<section id="contact" class="py-16 sm:py-24">
  <div class="section-shell">
    <div class="card-surface mx-auto max-w-3xl text-center">
      <p class="section-title">Contact</p>
      <h2 class="mt-3 text-2xl font-semibold tracking-tight text-ink dark:text-slate-50 sm:text-3xl">
        Let's Connect
      </h2>
      <p class="mx-auto mt-4 max-w-prose text-ink-muted dark:text-slate-400">
        Open to research collaborations in computer vision, anomaly detection, and industrial AI.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href={site.cvPath} class="btn-primary" download>
          Download CV
        </a>
        <a href={`mailto:${site.email}`} class="btn-secondary">
          {site.email}
        </a>
      </div>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4 text-sm">
        {
          site.affiliations.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-ink-muted underline-offset-4 transition hover:text-ink hover:underline dark:text-slate-400 dark:hover:text-slate-100"
            >
              {link.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>

<footer class="border-t border-paper-border py-8 dark:border-slate-800">
  <div class="section-shell flex flex-col gap-3 text-sm text-ink-muted dark:text-slate-500 sm:flex-row sm:items-center sm:justify-between">
    <p>© {new Date().getFullYear()} {site.name}</p>
    <p class="max-w-prose sm:text-right">{site.footerFocus}</p>
  </div>
</footer>

---
import { site } from '../data/site';
---

<header class="border-b border-paper-border bg-paper/90 backdrop-blur dark:border-slate-800 dark:bg-slate-950/90">
  <div class="section-shell flex items-center justify-between py-4">
    <a href="/" class="text-sm font-semibold tracking-tight text-ink dark:text-slate-100">
      {site.name}
    </a>
    <div class="flex items-center gap-3">
      <nav class="hidden items-center gap-6 text-sm text-ink-muted dark:text-slate-400 sm:flex">
        <a href="#about" class="transition hover:text-ink dark:hover:text-slate-100">About</a>
        <a href="#experience" class="transition hover:text-ink dark:hover:text-slate-100">Experience</a>
        <a href="#publications" class="transition hover:text-ink dark:hover:text-slate-100">Publications</a>
        <a href="#skills" class="transition hover:text-ink dark:hover:text-slate-100">Skills</a>
        <a href="#contact" class="transition hover:text-ink dark:hover:text-slate-100">Contact</a>
      </nav>
      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle dark mode"
        class="rounded-lg border border-paper-border p-2 text-ink-muted transition hover:bg-paper-soft hover:text-ink dark:border-slate-700 dark:text-slate-400 dark:hover:bg-slate-900 dark:hover:text-slate-100"
      >
        <svg class="h-4 w-4 dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
        </svg>
        <svg class="hidden h-4 w-4 dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
        </svg>
      </button>
    </div>
  </div>
</header>

<section id="about" class="border-b border-paper-border py-16 dark:border-slate-800 sm:py-24">
  <div class="section-shell grid gap-10 lg:grid-cols-[1.4fr_1fr] lg:items-start">
    <div>
      <p class="section-title">About Me</p>
      <h1 class="mt-3 text-3xl font-semibold tracking-tight text-ink dark:text-slate-50 sm:text-4xl lg:text-5xl">
        Deep Learning Researcher<br />
        <span class="text-ink-muted dark:text-slate-400">Computer Vision · SSL · Anomaly Detection</span>
      </h1>
      <p class="mt-6 max-w-prose text-base text-ink-muted dark:text-slate-300 sm:text-lg">
        {site.about}
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={site.cvPath} class="btn-primary" download>
          Download CV
        </a>
        <a href={`mailto:${site.email}`} class="btn-secondary">
          {site.email}
        </a>
      </div>
    </div>

    <aside class="card-surface">
      <dl class="space-y-5 text-sm">
        <div>
          <dt class="font-medium text-ink dark:text-slate-200">Education</dt>
          <dd class="mt-1 text-ink-muted dark:text-slate-400">
            Ph.D. in Electronics Engineering<br />
            Chungbuk National University
          </dd>
        </div>
        <div>
          <dt class="font-medium text-ink dark:text-slate-200">Affiliation</dt>
          <dd class="mt-1 text-ink-muted dark:text-slate-400">
            MSIS Lab · {site.location}
          </dd>
        </div>
        <div>
          <dt class="font-medium text-ink dark:text-slate-200">Research Focus</dt>
          <dd class="mt-1 text-ink-muted dark:text-slate-400">
            Self-supervised learning, pseudo-anomaly insertion, industrial visual inspection, and scalable deep learning architectures.
          </dd>
        </div>
      </dl>
    </aside>
  </div>
</section>

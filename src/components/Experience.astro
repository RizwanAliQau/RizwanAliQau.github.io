---
import { experience } from '../data/experience';
---

<section id="experience" class="border-b border-paper-border py-16 dark:border-slate-800 sm:py-24">
  <div class="section-shell">
    <div class="max-w-2xl">
      <p class="section-title">Professional Experience</p>
      <h2 class="mt-3 text-2xl font-semibold tracking-tight text-ink dark:text-slate-50 sm:text-3xl">
        Research & Engineering Timeline
      </h2>
      <p class="mt-4 text-ink-muted dark:text-slate-400">
        Academic and industry-facing research roles spanning national-scale funded projects and applied AI development.
      </p>
    </div>

    <ol class="mt-12 space-y-0">
      {
        experience.map((entry, index) => (
          <li class="relative grid gap-6 border-l border-paper-border pb-12 pl-8 last:pb-0 dark:border-slate-800 sm:grid-cols-[12rem_1fr] sm:gap-10 sm:pl-10">
            <span
              class="absolute -left-[5px] top-1.5 h-2.5 w-2.5 rounded-full bg-ink dark:bg-slate-100"
              aria-hidden="true"
            />
            <div class="text-sm">
              <p class="font-medium text-ink dark:text-slate-200">{entry.period}</p>
              <p class="mt-1 text-ink-muted dark:text-slate-500">{entry.location}</p>
            </div>

            <article class="card-surface">
              <h3 class="text-lg font-semibold text-ink dark:text-slate-100">{entry.role}</h3>
              <p class="mt-1 text-sm font-medium text-ink-muted dark:text-slate-400">
                {entry.organization}
              </p>
              <p class="mt-4 text-sm leading-7 text-ink-muted dark:text-slate-300">
                {entry.summary}
              </p>

              {entry.projects && entry.projects.length > 0 && (
                <div class="mt-6 space-y-4">
                  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-muted dark:text-slate-500">
                    Funded Projects
                  </p>
                  {entry.projects.map((project) => (
                    <div class="rounded-lg border border-paper-border bg-paper-soft p-4 dark:border-slate-800 dark:bg-slate-950">
                      <div class="flex flex-wrap items-center justify-between gap-2">
                        <h4 class="text-sm font-semibold text-ink dark:text-slate-100">
                          {project.title}
                        </h4>
                        <span class="rounded-full bg-ink px-2.5 py-0.5 text-xs font-medium text-white dark:bg-slate-100 dark:text-slate-900">
                          {project.funding}
                        </span>
                      </div>
                      <p class="mt-2 text-sm leading-6 text-ink-muted dark:text-slate-400">
                        {project.description}
                      </p>
                    </div>
                  ))}
                </div>
              )}

              {entry.highlights && entry.highlights.length > 0 && (
                <ul class="mt-6 space-y-2 text-sm text-ink-muted dark:text-slate-300">
                  {entry.highlights.map((highlight) => (
                    <li class="flex gap-2">
                      <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-ink-muted dark:bg-slate-500" />
                      <span>{highlight}</span>
                    </li>
                  ))}
                </ul>
              )}
            </article>
          </li>
        ))
      }
    </ol>
  </div>
</section>
